menu "Dashboard Config"

    config COUNTDOWN_DEFAULT_SEC
        int "Countdown default duration (seconds)"
        default 300
        range 1 86400
        help
            Default one-shot countdown duration in seconds.
            This value is used when no "cd_seconds" key exists in NVS.
            You can override it at runtime by writing to NVS directly.
            Examples: 60=1min  300=5min  600=10min  3600=1hr

endmenu
